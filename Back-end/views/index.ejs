<!DOCTYPE html>
<html>
  <head>
    <title>DataTables Switch</title>

    <!-- Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- DataTables -->
    <link
      rel="stylesheet"
      href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css"
    />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
  </head>

  <body>
    <div class="container">
      <h2>Data Tables</h2>

      <button id="btnAlumnos" class="btn btn-primary">ALUMNOS</button>
      <button id="btnAsignaturas" class="btn btn-primary">ASIGNATURAS</button>
      <button id="btnCursos" class="btn btn-primary">CURSOS</button>
      <button id="btnEntidades" class="btn btn-primary">ENTIDADES</button>
      <button id="btnGrupos" class="btn btn-primary">GRUPOS</button>
      <button id="btnNiveles" class="btn btn-primary">NIVELES</button>
      <button id="btnOfertas" class="btn btn-primary">OFERTAS</button>
      <button id="btnPeriodos" class="btn btn-primary">PERIODOS</button>
      <button id="btnProfesores" class="btn btn-primary">PROFESORES</button>
      <button id="btnTiposCurso" class="btn btn-primary">TIPOS CURSO</button>

      <br /><br />

      <table id="mainTable" class="display" style="width: 100%">
        <thead>
          <tr id="tableHead"></tr>
        </thead>
      </table>

      <!-- NUEVA SECCION PARA CREAR UN NUEVO REGISTRO -->

      <div class="mt-3 mb-4">
        <button type="button" id="btnOpenCreate" class="btn btn-success">
          Crear nuevo registro
        </button>
      </div>

      <div id="createSection" class="card p-3 mb-4" style="display: none">
        <h3>Crear nuevo registro</h3>

        <form id="createForm">
          <!-- Los campos del formulario se generarán dinámicamente -->
        </form>

        <button type="button" id="btnCreate" class="btn btn-success mt-3">
          Create
        </button>
      </div>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
      <script src="/js/alumnos.js"></script>
      <script src="/js/asignaturas.js"></script>
      <script src="/js/cursos.js"></script>
      <script src="/js/entidades.js"></script>
      <script src="/js/grupos.js"></script>
      <script src="/js/niveles.js"></script>
      <script src="/js/ofertas.js"></script>
      <script src="/js/periodos.js"></script>
      <script src="/js/profesores.js"></script>
      <script src="/js/tiposCurso.js"></script>
      <!-- Y FALTAN OTRAS ENTIDADES  -->
      <script src="/js/main.js"></script>

      <div class="modal fade" id="viewModal" tabindex="-1">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title">
                Informacion del registro de la entidad
              </h5>
              <button
                type="button"
                class="btn-close"
                data-bs-dismiss="modal"
              ></button>
            </div>

            <div class="modal-body">
              <form id="viewForm"></form>
            </div>

            <div class="modal-footer">
              <button
                type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal"
              >
                Close
              </button>
              <button type="button" id="btnUpdate" class="btn btn-success">
                Update
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
